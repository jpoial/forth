{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Forth File with GForth",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "/usr/bin/gforth",
            "args": [
                "${file}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
